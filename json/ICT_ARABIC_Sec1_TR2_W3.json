[{"id":1,"question":"ما المقصود بالجدول (Table) في قاعدة البيانات؟","type":"اختيار من متعدد","options":["مجموعة من البرامج","مجموعة من السجلات المرتبطة","ملف صور","جهاز تخزين"],"correct_answer":"مجموعة من السجلات المرتبطة"},{"id":2,"question":"العمود في جدول قاعدة البيانات يُسمى:","type":"اختيار من متعدد","options":["سجل","حقل","مفتاح","نموذج"],"correct_answer":"حقل"},{"id":3,"question":"الصف في جدول قاعدة البيانات يُسمى:","type":"اختيار من متعدد","options":["حقل","نموذج","سجل","استعلام"],"correct_answer":"سجل"},{"id":4,"question":"أي مما يلي يُستخدم للتمييز بين السجلات داخل الجدول؟","type":"اختيار من متعدد","options":["الحقل","النموذج","المفتاح الأساسي","الاستعلام"],"correct_answer":"المفتاح الأساسي"},{"id":5,"question":"المفتاح الأساسي (Primary Key) هو:","type":"اختيار من متعدد","options":["حقل يتكرر في الجدول","حقل يميز كل سجل تمييزاً فريداً","نموذج إدخال بيانات","استعلام بحث"],"correct_answer":"حقل يميز كل سجل تمييزاً فريداً"},{"id":6,"question":"أي من التالي يُعد مثالاً لحقل في جدول طالب؟","type":"اختيار من متعدد","options":["بيانات الطلاب","طالب واحد","رقم الجلوس","جدول النتائج"],"correct_answer":"رقم الجلوس"},{"id":7,"question":"ما وظيفة النماذج (Forms) في قواعد البيانات؟","type":"اختيار من متعدد","options":["تخزين البيانات","إدخال وعرض البيانات بسهولة","حذف الجداول","إنشاء الشبكات"],"correct_answer":"إدخال وعرض البيانات بسهولة"},{"id":8,"question":"أي عنصر يُستخدم لعرض البيانات بشكل منظم على الشاشة أو الطباعة؟","type":"اختيار من متعدد","options":["جدول","تقرير","مفتاح أساسي","حقل"],"correct_answer":"تقرير"},{"id":9,"question":"أي مما يلي يُعد مثالاً على سجل؟","type":"اختيار من متعدد","options":["عمود الاسم","صف يحتوي بيانات طالب واحد","اسم الجدول","نوع البيانات"],"correct_answer":"صف يحتوي بيانات طالب واحد"},{"id":10,"question":"نوع البيانات المناسب لتخزين الاسم هو:","type":"اختيار من متعدد","options":["رقم","تاريخ","نص","منطقية"],"correct_answer":"نص"},{"id":11,"question":"من شروط المفتاح الأساسي أن يكون:","type":"اختيار من متعدد","options":["قابل للتكرار","فارغ أحياناً","فريد وغير مكرر","من نوع نص فقط"],"correct_answer":"فريد وغير مكرر"},{"id":12,"question":"التقارير (Reports) تُستخدم في:","type":"اختيار من متعدد","options":["إدخال البيانات","تعديل الجداول","عرض البيانات في شكل منسق","إنشاء قواعد البيانات"],"correct_answer":"عرض البيانات في شكل منسق"}]